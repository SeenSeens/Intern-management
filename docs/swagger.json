  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": { "type": "object" }
        }
      },
      "Projects": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "name": { "type": "string", "example": "Phát triển AI Plugin" },
          "description": { "type": "string", "example": "" },
          "status": {
            "type": "string",
            "enum": [ "in_progress", "waiting", "on_hold", "completed" ],
            "example": "waiting"
          },
          "manager_id": { "type": "integer", "example": 1 },
          "start_date": { "type": "string", "format": "date","example": "2026-02-03" },
          "end_date": { "type": "string", "format": "date", "example": "2026-05-03" }
        }
      },
      "Tasks": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "project_id": { "type": "integer" },
          "title": { "type": "string", "example": "Xây dựng module API" },
          "description": { "type": "string", "example": "Tạo REST API cho Intern" },
          "priority": {
            "type": "string",
            "enum": [ "low", "medium", "hight", "critical" ],
            "example": "medium"
          },
          "assigned_by": { "type":  "integer" },
          "status": {
            "type": "string",
            "enum": [ "pending", "in_progress", "completed" ],
            "example": "pending"
          },
          "start_date": {
            "type": "string",
            "format": "date",
            "example": "2026-02-03"
          },
          "end_date": { "type": "string",
            "format": "date",
            "example": "2026-02-05"
          }
        }
      },
      "Report": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "intern_id": { "type": "integer", "example": 5 },
          "content": { "type": "string", "example": "Hoàn thành API module" },
          "created_at": { "type": "string", "example": "2026-02-28 10:53:26" }
        }
      }
    }
  },
